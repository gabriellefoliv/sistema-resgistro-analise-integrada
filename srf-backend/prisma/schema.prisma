  @@index([sampleTypeId], map: "resultado_cpcr_id_tipo_amostra_fkey")
  @@index([extractionTypeId], map: "resultado_cpcr_id_tipo_extracao_fkey")
  @@map("resultado_cpcr")
}

model qpcrResult {
  id                Int             @id @default(autoincrement())
  necropsyId        Int             @map("id_necropsia")
  sampleTypeId      Int             @map("id_tipo_amostra")
  performedDate     DateTime        @map("data_realizacao") @db.DateTime(0)
  targetGeneId      Int             @map("id_gene_alvo")
  suspiciousAgentId Int             @map("id_agente_suspeito")
  meanCt            Float           @map("ct_medio")
  estimatedCopies   Float           @map("copias_estimadas")
  qpcrStatusId      Int             @map("id_resultado_qpcr")
  control           String          @map("controle")
  suspiciousAgent   suspiciousAgent @relation(fields: [suspiciousAgentId], references: [id])
  targetGene        targetGene      @relation(fields: [targetGeneId], references: [id])
  necropsy          necropsy        @relation(fields: [necropsyId], references: [id])
  qpcrStatus        enumQpcrStatus  @relation(fields: [qpcrStatusId], references: [id])
  sampleType        qpcrSampleType  @relation(fields: [sampleTypeId], references: [id])

  @@unique([necropsyId, sampleTypeId])
  @@index([suspiciousAgentId], map: "resultado_qpcr_id_agente_suspeito_fkey")
  @@index([targetGeneId], map: "resultado_qpcr_id_gene_alvo_fkey")
  @@index([qpcrStatusId], map: "resultado_qpcr_id_resultado_qpcr_fkey")
  @@index([sampleTypeId], map: "resultado_qpcr_id_tipo_amostra_fkey")
  @@map("resultado_qpcr")
}

model extractionType {
  id         Int          @id @default(autoincrement())
  name       String       @map("nome")
  cpcrResult cpcrResult[]

  @@map("tipo_extracao")
}

model targetGene {
  id         Int          @id @default(autoincrement())
  name       String       @map("nome")
  cpcrResult cpcrResult[]
  qpcrResult qpcrResult[]

  @@map("gene_alvo")
}

model suspiciousAgent {
  id         Int          @id @default(autoincrement())
  name       String       @map("nome")
  cpcrResult cpcrResult[]
  qpcrResult qpcrResult[]

  @@map("agente_suspeito")
}

model enumCpcrMethod {
  id         Int          @id @default(autoincrement())
  name       String       @map("nome")
  cpcrResult cpcrResult[]

  @@map("enum_metodo_cpcr")
}

model enumCpcrStatus {
  id         Int          @id @default(autoincrement())
  name       String       @map("nome")
  cpcrResult cpcrResult[]

  @@map("enum_status_cpcr")
}

model enumQpcrStatus {
  id         Int          @id @default(autoincrement())
  name       String       @map("nome")
  qpcrResult qpcrResult[]

  @@map("enum_status_qpcr")
}
